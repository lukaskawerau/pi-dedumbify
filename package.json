{
  "name": "pi-dedumbify",
  "version": "0.1.0",
  "description": "Pi extension for executable spaced repetition with FSRS scheduling",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "spaced-repetition",
    "fsrs",
    "typescript",
    "python"
  ],
  "author": "Lukas Kawerau",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukaskawerau/pi-dedumbify.git"
  },
  "homepage": "https://github.com/lukaskawerau/pi-dedumbify#readme",
  "bugs": {
    "url": "https://github.com/lukaskawerau/pi-dedumbify/issues"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "npm run typecheck && npm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "ts-fsrs": "^5.2.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.58.1",
    "@mariozechner/pi-tui": "^0.58.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
